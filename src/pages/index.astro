---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import { withBase } from '../utils/path';

const pageDescription = `${site.tagline} ${site.openTo}`;
---

<BaseLayout title={site.name} description={pageDescription} path="/">
  <section class="mb-12">
    <h1 class="mb-2 text-3xl font-bold tracking-tight text-gray-900">
      {site.name}
    </h1>
    <p class="mb-6 text-lg text-accent">{site.tagline}</p>
    <div class="space-y-4 leading-relaxed text-gray-700">
      {site.bio.map((paragraph) => <p>{paragraph}</p>)}
      <p>{site.openTo}</p>
    </div>
  </section>

  <section class="rounded-lg border border-gray-200 bg-gray-50 p-6" aria-labelledby="projects-cta-heading">
    <h2 id="projects-cta-heading" class="mb-2 text-lg font-semibold text-gray-900">
      Skills &amp; Projects
    </h2>
    <p class="mb-4 leading-relaxed text-gray-700">
      My skills and full project case studies live on the Projects page — browse by category, sort by
      skill tags, and open any project for methodology, results, and deliverables.
    </p>
    <a
      href={withBase('/projects')}
      class="inline-block text-sm font-medium text-accent hover:underline"
    >
      View skills and projects &rarr;
    </a>
  </section>
</BaseLayout>
