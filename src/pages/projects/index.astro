---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import ProjectFilter from '../../components/ProjectFilter.astro';
import ProjectSkillSort from '../../components/ProjectSkillSort.astro';
import ProjectGridAnalytics from '../../components/ProjectGridAnalytics.astro';
import { site } from '../../data/site';
import { getPublishedProjects } from '../../data/project-utils';

const publishedProjects = getPublishedProjects();
---

<BaseLayout
  title="Projects"
  description={`${site.name} — portfolio projects in LLM, agentic AI, data science, and applied analytics. ${site.tagline}`}
  path="/projects"
>
  <h1 class="mb-2 text-3xl font-bold tracking-tight text-gray-900">Projects</h1>
  <p class="mb-8 text-gray-600">
    {publishedProjects.length} projects across LLM, agentic AI, data science, and applied analytics, drawn from
    SMU MITB coursework and hands-on business context.
  </p>

  <ProjectFilter />

  <ProjectSkillSort />

  <div class="grid gap-6" id="project-grid">
    {
      publishedProjects.map((project, index) => (
        <div
          data-project-category={project.category}
          data-project-skills={project.skills.join('||')}
          data-project-order={index}
          data-project-slug={project.slug}
          data-project-title={project.title}
        >
          <ProjectCard project={project} />
        </div>
      ))
    }
  </div>

  <ProjectGridAnalytics />
</BaseLayout>
