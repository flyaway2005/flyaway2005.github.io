---
import type { Project } from '../types/project';
import CategoryTag from './CategoryTag.astro';
import TopicTag from './TopicTag.astro';
import TechBadge from './TechBadge.astro';
import { sortBySkillOrder } from '../data/skills';
import { withBase } from '../utils/path';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const projectHref = withBase(`/projects/${project.slug}`);
const techStack = sortBySkillOrder(project.techStack);
---

<article class="rounded-lg border border-gray-200 p-5">
  <div class="mb-3 flex flex-wrap gap-2">
    <CategoryTag category={project.category} />
    <TopicTag topic={project.topic} />
  </div>
  <h2 class="mb-2 text-lg font-semibold text-gray-900">
    <a href={projectHref} class="hover:text-accent">
      {project.title}
    </a>
  </h2>
  <p class="mb-4 text-sm leading-relaxed text-gray-600">{project.summary}</p>
  {
    techStack.length > 0 && (
      <div class="mb-4 flex flex-wrap gap-2">
        {techStack.map((tech) => (
          <TechBadge label={tech} />
        ))}
      </div>
    )
  }
  <a href={projectHref} class="text-sm font-medium text-accent hover:underline">
    View project
  </a>
</article>
