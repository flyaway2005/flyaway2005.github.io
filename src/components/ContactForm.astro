---
import { site } from '../data/site';
import { siteUrl } from '../utils/path';

const hasFormEndpoint = Boolean(site.contactFormEndpoint);
const thankYouUrl = siteUrl('/contact?sent=1');
---

<form
  id="contact-form"
  method={hasFormEndpoint ? 'POST' : undefined}
  action={hasFormEndpoint ? site.contactFormEndpoint : undefined}
  class="space-y-4"
>
  {
    hasFormEndpoint && (
      <>
        <input type="hidden" name="_subject" value="Portfolio contact" />
        <input type="hidden" name="_next" value={thankYouUrl} />
      </>
    )
  }

  <div>
    <label for="contact-email" class="mb-1 block text-sm font-medium text-gray-700">
      Your email
    </label>
    <input
      id="contact-email"
      type="email"
      name="email"
      required
      autocomplete="email"
      class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
      placeholder="you@example.com"
    />
  </div>

  <div>
    <label for="contact-message" class="mb-1 block text-sm font-medium text-gray-700">
      Message
    </label>
    <textarea
      id="contact-message"
      name="message"
      required
      rows={6}
      class="w-full resize-y rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
      placeholder="What would you like to discuss?"
    />
  </div>

  <button
    type="submit"
    class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:opacity-90"
  >
    Send message
  </button>

  <p id="contact-success" class="hidden text-sm text-gray-700" role="status"></p>
</form>

{
  !hasFormEndpoint && (
    <script define:vars={{ recipientEmail: site.email }}>
      const form = document.getElementById('contact-form');

      form?.addEventListener('submit', (event) => {
        event.preventDefault();
        if (!(form instanceof HTMLFormElement)) return;

        const emailInput = form.elements.namedItem('email');
        const messageInput = form.elements.namedItem('message');
        if (!(emailInput instanceof HTMLInputElement) || !(messageInput instanceof HTMLTextAreaElement)) {
          return;
        }

        const senderEmail = emailInput.value.trim();
        const message = messageInput.value.trim();
        const subject = encodeURIComponent('Portfolio contact');
        const body = encodeURIComponent(`From: ${senderEmail}\n\n${message}`);
        window.location.href = `mailto:${recipientEmail}?subject=${subject}&body=${body}`;
      });
    </script>
  )
}

<script>
  const params = new URLSearchParams(window.location.search);
  if (params.get('sent') === '1') {
    const success = document.getElementById('contact-success');
    if (success) {
      success.textContent = 'Thanks — your message has been sent. I will get back to you soon.';
      success.classList.remove('hidden');
    }
    const form = document.getElementById('contact-form');
    form?.classList.add('hidden');
  }
</script>
