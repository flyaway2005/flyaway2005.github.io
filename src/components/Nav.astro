---
import { site } from '../data/site';

const navItems = [
  { href: '/', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/95 backdrop-blur-sm">
  <nav
    class="mx-auto flex max-w-[760px] items-center justify-between px-6 py-4"
    aria-label="Main navigation"
  >
    <a href="/" class="text-sm font-semibold text-gray-900 hover:text-accent">
      {site.name}
    </a>
    <ul class="flex items-center gap-1 text-sm text-gray-600">
      {
        navItems.map((item, i) => {
          const isActive =
            item.href === '/'
              ? currentPath === '/'
              : currentPath === item.href || currentPath.startsWith(`${item.href}/`);
          return (
            <>
              {i > 0 && <li aria-hidden="true" class="px-1 text-gray-400">·</li>}
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'hover:text-accent',
                    isActive && 'font-medium text-accent',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            </>
          );
        })
      }
    </ul>
  </nav>
</header>
